    "int128_fastio": {
        "prefix": "lllio",
        "body": [
            "#pragma region fastio_for_int128",
            "__int128 read() {",
            "\t__int128 x = 0;",
            "\tint w = 0;",
            "\tchar ch;",
            "\twhile (!isdigit(ch)) {",
            "\t\tw |= ch == '-'; ch = getchar();",
            "\t}",
            "\twhile (isdigit(ch)) ",
            "\t\tx = (x << 3) + (x << 1) + (ch ^ 48), ch = getchar();",
            "\treturn w ? -x : x;",
            "}",
            "",
            "void output(__int128 x) {",
            "\tif (x < 0) {",
            "\t\tputchar('-');",
            "\t\tx *= -1;",
            "\t}",
            "\tif (x > 9)",
            "\t\toutput(x / 10);",
            "\tputchar(x % 10 + '0');",
            "}",
            "#pragma endregion"
        ]
    },
    "Dancing Links X": {
        "prefix": "dlx",
        "body": [
            "#include <bits/stdc++.h>",
            "using namespace std;",
            "",
            "const int N = 1e5 + 5;",
            "int n, m, idx, first[N], siz[N];",
            "int L[N], R[N], U[N], D[N];",
            "int col[N], row[N];",
            "",
            "void remove(int c)",
            "{",
            "    int i, j;",
            "    L[R[c]] = L[c], R[L[c]] = R[c];",
            "",
            "    for (i = D[c]; i != c; i = D[i]) {",
            "        for (j = R[i]; j != i; j = R[j]) {",
            "            U[D[j]] = U[j], D[U[j]] = D[j], --siz[col[j]];",
            "        }",
            "    }",
            "}",
            "",
            "void recover(int c)",
            "{",
            "    int i, j;",
            "",
            "    for (i = U[c]; i != c; i = U[i]) {",
            "        for (j = L[i]; j != i; j = L[j]) {",
            "            U[D[j]] = D[U[j]] = j, ++siz[col[j]];",
            "        }",
            "    }",
            "    L[R[c]] = R[L[c]] = c;",
            "}",
            "",
            "void build(int r, int c)",
            "{",
            "    n = r, m = c;",
            "    for (int i = 0; i <= c; ++i) {",
            "        L[i] = i - 1, R[i] = i + 1;",
            "        U[i] = i, D[i] = i;",
            "    }",
            "    L[0] = c, R[c] = 0, idx = c;",
            "    memset(first, 0, sizeof(first));",
            "    memset(siz, 0, sizeof(siz));",
            "}",
            "",
            "void insert(int r, int c)",
            "{",
            "    row[++idx] = r, col[idx] = c, ++siz[c];",
            "    U[idx] = c, D[idx] = D[c], U[D[c]] = idx, D[c] = idx;",
            "    if (!first[r]) {",
            "        first[r] = L[idx] = R[idx] = idx;",
            "    } else {",
            "        L[idx] = first[r], R[idx] = R[first[r]];",
            "        L[R[first[r]]] = idx, R[first[r]] = idx;",
            "    }",
            "}",
            "",
            "int ans = 0;",
            "int stk[N];",
            "",
            "bool dance(int dep)",
            "{",
            "    int i, j, c = R[0];",
            "    if (!R[0]) {",
            "        ans = dep;",
            "        return true;",
            "    }",
            "    for (i = R[0]; i != 0; i = R[i])",
            "        if (siz[i] < siz[c])",
            "            c = i;",
            "    remove(c);",
            "    for (i = D[c]; i != c; i = D[i]) {",
            "        stk[dep] = row[i];",
            "        for (j = R[i]; j != i; j = R[j])",
            "            remove(col[j]);",
            "        if (dance(dep + 1))",
            "            return true;",
            "        for (j = L[i]; j != i; j = L[j])",
            "            recover(col[j]);",
            "    }",
            "    recover(c);",
            "    return false;",
            "}",
            "",
            "int main()",
            "{",
            "    int n, m;",
            "    cin >> n >> m;",
            "    build(n, m);",
            "    for (int i = 1; i <= n; ++i) {",
            "        for (int j = 1; j <= m; ++j) {",
            "            int x;",
            "            cin >> x;",
            "            if (x == 1) {",
            "                insert(i, j);",
            "            }",
            "        }",
            "    }",
            "    dance(1);",
            "    if (ans != 0) {",
            "        for (int i = 1; i < ans; ++i) {",
            "            cout << stk[i] << \" \";",
            "        }",
            "        cout << endl;",
            "    } else {",
            "        cout << \"No Solution!\";",
            "    }",
            "}"
        ],
        "description": "Dancing Links X"
    }
}
